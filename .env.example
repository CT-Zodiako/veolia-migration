# Oracle (docker-compose)
ORACLE_IMAGE=gvenzl/oracle-free:23-slim
ORACLE_CONTAINER_NAME=veolia-oracle
ORACLE_PORT=1521
ORACLE_EM_PORT=5500
ORACLE_APP_USER=veolia_app
ORACLE_APP_PASSWORD=change_me_app_password
ORACLE_DATABASE_PASSWORD=change_me_sys_password
